            { "organism": "Viridans streptococcus",               "hemolysis": "γ", "morphology": "cocci in chain",                       "bacitracin": "NT","PPR": "NT", "bile_esculin": "-", "nacl_6_5": "-", "optochin": "NT",        "other": null }
