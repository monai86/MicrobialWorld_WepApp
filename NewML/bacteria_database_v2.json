    "enterobacterales": {
      "id": "enterobacterales",
      "label": "Enterobacterales (Gram Negative Bacilli)",
      "gram": "negative",
      "morphology": "bacilli",
      "initial_tests": {
        "oxidase": "- (except Plesiomonas shigelloides = +)",
        "MacConkey": "+ (grows)"
      },
      "key_tests": ["TSI", "indole", "MR", "VP", "citrate", "motility", "urease", "LD", "OD", "PD", "malonate", "gas_glucose", "lactose", "dnase", "arabinose"],
      "macconkey": {
        "LF_pink": ["E. coli", "Klebsiella spp.", "Enterobacter spp.", "Serratia rubidea", "Citrobacter freundii", "Salmonella arizonae"],
        "NLF_colorless": ["Salmonella spp.", "Shigella spp.", "Serratia marcescens", "Edwardsiella tarda", "Proteus spp.", "Providencia spp.", "Citrobacter spp.", "Morganella morganii", "Yersinia spp."]
      },
      "tsi_decision_trees": {
        "A_AG": {
          "pattern": "A/AG (acid slant, acid butt with gas)",
          "organisms": ["E. coli", "Enterobacter spp.", "Klebsiella spp.", "Serratia (little gas)", "Citrobacter koseri"],
          "key_flow": "IMViC → (+,+,-,−) = E.coli | (−,−,+,+) motile/OD +/+ = Enterobacter/Serratia | (−,−,+,+) motile/OD −/− = Klebsiella | (+,+,−,+) = C.koseri",
          "enterobacter_vs_serratia": "DNase+/Arabinose− = Serratia; DNase−/Arabinose+ = Enterobacter"
        },
        "A_A": {
          "pattern": "A/A (acid slant, acid butt, no gas)",
          "organisms": ["Yersinia enterocolitica", "Plesiomonas shigelloides (oxidase+)", "Serratia rubidaea", "Serratia marcescens", "Pantoea agglomerans"],
          "key_flow": "IMViC(+,+,−,−) + urease+ = Yersinia; motile+/urease− = Plesiomonas (oxidase+); IMViC(−,−,+,+) DNase+ = Serratia"
        },
        "A_AG_H2S": {
          "pattern": "A/AG H2S (acid butt with gas and H2S)",
          "organisms": ["Citrobacter freundii", "Proteus vulgaris", "Proteus penneri", "Salmonella arizonae"],
          "key_flow": "IMViC(+,+,−,−) PD+ urease+ = P.vulgaris | IMViC(−,+,−,−) PD+ urease+ = P.penneri | IMViC(−,+,−,+) LD/OD −/− = C.freundii | IMViC(−,+,−,+) LD/OD +/+ = S.arizonae"
        },
        "K_A": {
          "pattern": "K/A (alkaline slant, acid butt, no gas, no H2S)",
          "organisms": ["Shigella spp.", "Providencia spp.", "Yersinia pseudotuberculosis"],
          "key_flow": "IMViC(+,+,−,+) urease+/PD+ = Providencia rettgeri | IMViC(+,+,−,+) urease−/PD+ = P.stuartii | IMViC(+,−,−,−) urease+ = Y.pseudotuberculosis | IMViC(−,+,−,−) = Shigella",
          "shigella": "Mannitol− = S.dysenteriae; OD+ = S.sonnei; Mannitol+ indole− = S.flexneri/boydii"
        },
        "K_AG": {
          "pattern": "K/AG (alkaline slant, acid butt with gas)",
          "organisms": ["Morganella morganii", "Klebsiella ozaenae", "Salmonella Paratyphi A", "Citrobacter amalonaticus", "Providencia alcalifaciens", "Hafnia alvei"],
          "key_flow": "IMViC(+,+,−,−) PD+/urease+ = Morganella | Motile−/OD− = K.ozaenae | Motile+/OD+ Sal.Paratyphi A | IMViC(+,+,−,+) urease+/PD+ = P.alcalifaciens | IMViC(−,+,+,−) = H.alvei"
        },
        "K_AG_H2S": {
          "pattern": "K/AG H2S 3+ (most H2S)",
          "organisms": ["Salmonella enteritidis (most)", "Edwardsiella tarda", "Proteus mirabilis", "Citrobacter freundii"],
          "key_flow": "IMViC(+,+,−,−) mannitol− = Edwardsiella tarda | IMViC(−,+,+,+) PD+/urease+ = P.mirabilis | IMViC(−,+,−,+) LD/OD +/+ = Salmonella | IMViC(−,+,−,+) LD/OD −/− = C.freundii"
        },
        "K_A_H2S_1plus": {
          "pattern": "K/A H2S 1+ (small amount H2S)",
          "organisms": ["Salmonella Typhi"],
          "key_flow": "IMViC(−,+,−,−) LD+/OD− = S. Typhi (serotype D)"
        }
      },
      "species_tables": {
        "klebsiella": {
          "description": "Klebsiella species differentiation",
          "tests": ["Indole", "Urease", "Malonate"],
          "organisms": {
            "K_pneumoniae": { "TSI": "A/AG", "Indole": "-", "Urease": "+", "Malonate": "+", "Motility": "-" },
            "K_oxytoca":    { "TSI": "A/AG", "Indole": "+", "Urease": "+", "Malonate": "+", "Motility": "-" },
            "K_ozaenae":    { "TSI": "K/AG", "Indole": "-", "Urease": "-", "Malonate": "-", "Motility": "-" },
            "K_aerogenes":  { "TSI": "A/AG", "Indole": "-", "Urease": "-", "Malonate": "+", "Motility": "+" }
          }
        },
        "serratia": {
