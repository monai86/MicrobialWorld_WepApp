  "groups": {

    "gpc_cluster": {
      "id": "gpc_cluster",
      "label": "Gram Positive Cocci in Cluster",
      "gram": "positive",
      "morphology": "cocci",
      "arrangement": "cluster",
      "initial_split": {
        "test": "Catalase",
        "positive": "Staphylococcus spp. / Micrococcus spp.",
        "negative": "→ see GPC Chain group"
      },
      "key_tests": ["glucose_OF", "catalase", "coagulase", "mannitol_MSA", "dnase", "novobiocin", "OD"],
      "decision_tree": [
        "Catalase + → Staphylococcus or Micrococcus",
        "Glucose O/F: +/+ → Staphylococcus spp.",
        "  Coagulase + → S. aureus",
        "  Coagulase − → CoNS → Novobiocin / OD test:",
        "    Novobiocin S + OD + → S. lugdunensis",
        "    Novobiocin S + OD − → S. epidermidis",
        "    Novobiocin R → S. saprophyticus",
        "Glucose O/F: +/- or -/- → Micrococcus spp."
      ],
      "organisms": {
        "S_aureus": {
          "name": "Staphylococcus aureus",
          "colony_bap": "Golden/yellow, β-hemolysis (or γ), 2-3mm, convex, opaque",
          "gram_stain": "GPC in clusters, large cocci ~1µm",
          "tests": {
            "catalase": "+",
            "oxidase": "-",
            "glucose_OF": "+/+ (fermentative)",
            "coagulase_tube": "+",
            "coagulase_slide": "+",
            "mannitol_MSA": "+ (yellow zone)",
            "dnase": "+",
            "hemolysis": "β (most strains)",
            "pigment": "golden yellow",
            "thermostable_nuclease": "+",
            "protein_A": "+"
          }
        },
        "S_epidermidis": {
          "name": "Staphylococcus epidermidis",
          "colony_bap": "White/grey, non-hemolytic, 1-2mm",
          "gram_stain": "GPC in clusters",
          "tests": {
            "catalase": "+",
            "coagulase_tube": "-",
            "coagulase_slide": "-",
            "mannitol_MSA": "-",
            "dnase": "-",
            "novobiocin": "S",
            "OD": "-",
            "urease": "+",
            "hemolysis": "γ (none)"
          }
        },
        "S_lugdunensis": {
          "name": "Staphylococcus lugdunensis",
          "colony_bap": "White, small, may have β or γ hemolysis",
          "tests": {
            "catalase": "+",
            "coagulase_tube": "-",
            "novobiocin": "S",
            "OD": "+",
            "slide_coagulase": "+/-",
            "note": "Virulent CoNS — can cause endocarditis"
          }
        },
        "S_saprophyticus": {
          "name": "Staphylococcus saprophyticus",
          "colony_bap": "White/yellow, non-hemolytic, 2-3mm",
          "tests": {
            "catalase": "+",
            "coagulase_tube": "-",
            "novobiocin": "R (key test!)",
            "OD": "-",
            "urease": "+",
            "mannitol_MSA": "±",
            "hemolysis": "γ"
          },
          "note": "Common UTI in young women"
        },
        "S_haemolyticus": {
          "name": "Staphylococcus haemolyticus",
          "tests": {
            "catalase": "+",
            "coagulase_tube": "-",
            "hemolysis": "β",
            "novobiocin": "S",
            "dnase": "±",
            "OD": "-"
          }
        },
        "Micrococcus": {
          "name": "Micrococcus spp.",
          "colony_bap": "Yellow/cream, large, dry, may fluoresce",
          "gram_stain": "GPC in tetrads or irregular clusters",
          "tests": {
            "catalase": "+",
            "oxidase": "+/-",
            "glucose_OF": "+/- or -/- (oxidative or inert)",
            "note": "Distinguished from Staph by Glucose O/F (Staph = +/+, Micrococcus = +/- or -/-)"
          }
        }
      }
    },

    "gpc_chain": {
      "id": "gpc_chain",
      "label": "Gram Positive Cocci in Chain / Pairs",
      "gram": "positive",
      "morphology": "cocci",
      "arrangement": "chain or pairs",
      "initial_split": {
        "test": "Catalase",
        "positive": "→ see GPC Cluster (Staphylococcus)",
        "negative": "Streptococcus / Enterococcus"
      },
      "key_tests": ["hemolysis", "bacitracin", "optochin", "bile_solubility", "camp", "pyr", "hippurate", "bile_esculin", "nacl_6_5"],
      "decision_tree_beta": [
        "β-hemolysis → Bacitracin test:",
        "  Bacitracin S → S. pyogenes (Group A)",
        "  Bacitracin R → PPR (PYR) test:",
        "    PPR+ → Group B Streptococcus (S. agalactiae) — also CAMP+",
        "    PPR- → Bile esculin:",
        "      Bile esculin + → β-Streptococcus Group D",
        "        6.5% NaCl +  → β-Enterococcus spp.",
        "        6.5% NaCl −  → β-Streptococcus Group D (non-Entero)",
        "      Bile esculin − → Streptococcus not group A,B,D"
      ],
      "decision_tree_alpha": [
        "α-hemolysis → Optochin test:",
        "  Optochin S → S. pneumoniae (also bile soluble)",
        "  Optochin R → Bile esculin:",
        "    Bile esculin + →",
        "      6.5% NaCl + → α-Enterococcus spp.",
        "      6.5% NaCl − → α-Streptococcus Group D",
        "    Bile esculin − → Viridans Streptococcus"
      ],
      "decision_tree_gamma": [
        "γ-hemolysis (none) → Bile esculin:",
        "  Bile esculin − → Viridans Streptococcus",
        "  Bile esculin + →",
        "    6.5% NaCl + → γ-Enterococcus spp.",
        "    6.5% NaCl − → γ-Streptococcus Group D"
      ],
      "organisms": {
        "S_pyogenes": {
          "name": "Streptococcus pyogenes (Group A)",
          "colony_bap": "Small, β-hemolytic, transparent, 0.5-1mm",
          "gram_stain": "GPC in chains",
          "tests": {
            "hemolysis": "β",
            "catalase": "-",
            "bacitracin": "S",
            "pyr": "+",
            "camp": "-",
            "bile_esculin": "-",
            "nacl_6_5": "-",
            "optochin": "R",
            "hippurate": "-",
            "lancefield_group": "A"
          }
        },
