  "biochemical_tests_reference": {
    "title": "Biochemical Tests Quick Reference",
    "tests": [
      { "abbreviation": "TSI",     "full_name": "Triple Sugar Iron agar",            "interpretation": "Slant/Butt: K=alkaline (red/pink), A=acid (yellow); Gas=bubbles/cracks; H2S=black precipitate" },
      { "abbreviation": "MR",      "full_name": "Methyl Red",                         "interpretation": "+ = mixed acid fermentation (red color); E. coli +, Klebsiella -" },
      { "abbreviation": "VP",      "full_name": "Voges-Proskauer",                    "interpretation": "+ = butanediol fermentation (pink/red color); Klebsiella +, E. coli -" },
      { "abbreviation": "LD",      "full_name": "Lysine Decarboxylase",               "interpretation": "+ = purple color (alkaline); used to differentiate Salmonella, E. coli, etc." },
      { "abbreviation": "OD",      "full_name": "Ornithine Decarboxylase",            "interpretation": "+ = purple color (alkaline)" },
      { "abbreviation": "AD",      "full_name": "Arginine Dihydrolase",               "interpretation": "+ = purple color (alkaline)" },
      { "abbreviation": "PD",      "full_name": "Phenylalanine Deaminase",            "interpretation": "+ = green color after adding FeCl3; Proteus, Morganella, Providencia +" },
      { "abbreviation": "O/F",     "full_name": "Oxidation/Fermentation test",        "interpretation": "O = oxidative (open tube only), F = fermentative (both tubes), - = no reaction" },
      { "abbreviation": "CAMP",    "full_name": "Christie-Atkins-Munch-Petersen test","interpretation": "+ = enhanced hemolysis near Staph aureus streak; Group B Streptococcus +" },
      { "abbreviation": "Reverse CAMP","full_name": "Reverse CAMP test",              "interpretation": "+ = inhibition of hemolysis near Staph aureus; C. pseudotuberculosis, C. ulcerans, A. haemolyticum +" },
      { "abbreviation": "PPR",     "full_name": "Pyrrolidonyl Arylamidase",           "interpretation": "+ = red/pink after adding PYR reagent; Group A Streptococcus +" },
      { "abbreviation": "King P",  "full_name": "Pigment on King B agar",             "interpretation": "Pseudomonas aeruginosa produces pyocyanin (blue-green) on King B agar" },
      { "abbreviation": "King F",  "full_name": "Fluorescence on King A agar",        "interpretation": "Fluorescent pseudomonads produce fluorescein visible under UV light" },
      { "abbreviation": "LIA",     "full_name": "Lysine Iron Agar",                   "interpretation": "Tests lysine decarboxylase and H2S production together" },
      { "abbreviation": "MIO",     "full_name": "Motility Indole Ornithine",          "interpretation": "Combined test: Motility = spreading growth; Indole = pink ring with Kovacs; Ornithine = color change" },
      { "abbreviation": "DNase",   "full_name": "Deoxyribonuclease",                  "interpretation": "+ = clear halo around colony on DNase agar with HCl" },
      { "abbreviation": "Optochin","full_name": "Optochin susceptibility (P disk)",   "interpretation": "S. pneumoniae is sensitive (zone ≥14 mm); other streptococci are resistant; use candle jar" },
      { "abbreviation": "Novobiocin","full_name": "Novobiocin susceptibility (5 µg)", "interpretation": "S. saprophyticus is resistant (R, zone <14 mm); most other coagulase-negative Staph are sensitive" },
      { "abbreviation": "Bacitracin","full_name": "Bacitracin susceptibility (0.04 U)","interpretation": "Group A Streptococcus (S. pyogenes) is sensitive; others are resistant" },
      { "abbreviation": "Bile esculin","full_name": "Bile esculin hydrolysis",         "interpretation": "+ = black color; Enterococcus and Group D Streptococcus +" },
      { "abbreviation": "6.5% NaCl","full_name": "Growth in 6.5% NaCl broth",        "interpretation": "+ = turbid growth; only Enterococcus among catalase-negative cocci grows" },
      { "abbreviation": "Coagulase","full_name": "Coagulase test",                    "interpretation": "+ = clot formation; S. aureus is the main coagulase-positive Staphylococcus" }
    ]
  },

  "symbol_legend": {
    "+":   "Positive (>80% of strains positive)",
    "-":   "Negative (>80% of strains negative)",
    "±":   "Variable (<80% of strains positive, some strains give positive, some negative)",
    "NT":  "Not Tested",
    "ND":  "Not Determined",
    "S":   "Sensitive (in susceptibility context)",
    "R":   "Resistant (in susceptibility context)",
    "A":   "Acid (yellow) in TSI",
    "K":   "Alkaline (pink/red) in TSI",
    "O":   "Oxidative only in O/F test",
    "F":   "Fermentative in O/F test",
    "β":   "Beta-hemolysis (complete clear zone)",
    "α":   "Alpha-hemolysis (partial green zone)",
    "γ":   "Gamma-hemolysis (no hemolysis)",
    "RT":  "Room temperature"
  }
}
