  "specimen_to_media": {
    "blood": {
      "plates": ["Blood agar (BAP)", "MacConkey (MCA)", "Chocolate agar (CA)"],
      "condition": "37°C, 5% CO₂ for CA; anaerobic bottle",
      "notes": "Blood culture bottle → subculture to plates on alarm signal"
    },
    "urine": {
      "plates": ["Blood agar (BAP)", "MacConkey (MCA)", "CLED agar"],
      "condition": "37°C, 18-24h",
      "notes": "≥10⁵ CFU/mL = significant; semi-quantitative streak method"
    },
    "csf": {
      "plates": ["Blood agar (BAP)", "Chocolate agar (CA)", "MacConkey (MCA)"],
      "condition": "37°C, 5% CO₂, IMMEDIATE processing",
      "notes": "Gram stain FIRST. Look for: GN diplococci (N. meningitidis), GP diplococci (S. pneumoniae), GP coccobacilli (L. monocytogenes)"
    },
    "sputum": {
      "plates": ["Blood agar (BAP)", "MacConkey (MCA)", "Chocolate agar (CA)"],
      "condition": "37°C, 5% CO₂ for CA, 18-48h",
      "notes": "Gram stain screen: >25 PMN/LPF + <10 epithelial cells/LPF = acceptable"
    },
    "stool": {
      "plates": ["MacConkey (MCA)", "SS agar", "XLD agar", "TCBS agar (Vibrio?)", "HEA"],
      "condition": "37°C, 18-24h",
      "notes": "NLF + H₂S on SS = Salmonella; NLF no H₂S = Shigella; TCBS if seafood history"
    },
    "wound_swab": {
      "plates": ["Blood agar (BAP)", "MacConkey (MCA)", "MSA (Staph suspected)", "Anaerobic plate (deep wound)"],
      "condition": "37°C aerobic ± anaerobic",
      "notes": "Gram stain guides further testing; β-hemolysis on BAP → Staph/Strep workup"
    },
    "genital_swab": {
      "plates": ["Thayer-Martin (TMA)", "Blood agar (BAP)", "Chocolate agar (CA)", "Wet prep (Gardnerella clue cells)"],
      "condition": "37°C, 5% CO₂ critical for Neisseria, 24-48h",
      "notes": "GN diplococci intracellular → oxidase test → N. gonorrhoeae"
    },
    "throat_swab": {
      "plates": ["Blood agar (BAP)", "Blood agar + Bacitracin disc"],
      "condition": "37°C, 5% CO₂, 18-24h",
      "notes": "β-hemolysis + Bacitracin S → GAS (S. pyogenes); Candle jar or CO₂ incubator"
    },
    "ear_swab": {
      "plates": ["Blood agar (BAP)", "MacConkey (MCA)", "Chocolate agar (CA)"],
      "condition": "37°C, 18-24h",
      "notes": "Watch for P. aeruginosa (otitis externa), S. pneumoniae (otitis media)"
    }
  },

