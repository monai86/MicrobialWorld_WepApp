          "tests": ["OD", "Malonate", "Arabinose", "Sorbitol", "Adonitol"],
          "organisms": {
            "S_marcescens":  { "OD": "+", "Malonate": "-", "Arabinose": "- (key!)", "Sorbitol": "+", "Adonitol": "-", "Pigment": "pink-red at RT" },
            "S_liquefaciens": { "OD": "+", "Malonate": "-", "Arabinose": "+", "Sorbitol": "+", "Adonitol": "-" },
            "S_rubidaea":    { "OD": "-", "Malonate": "+", "Arabinose": "+", "Sorbitol": "-", "Adonitol": "+", "MacConkey": "LF" }
