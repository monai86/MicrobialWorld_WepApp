    "vibrio": {
      "id": "vibrio",
      "label": "Vibrionaceae",
      "gram": "negative",
      "morphology": "curved rods",
      "initial_tests": {
        "oxidase": "+",
        "TCBS": "selective medium — sucrose fermentation",
        "key_separation": "Gas from glucose: + = Aeromonas; − = Vibrio (except V.furnissii)"
      },
      "key_tests": ["TCBS_colony", "TSI", "sucrose", "NaCl_0pct", "NaCl_1pct", "NaCl_6pct", "NaCl_8pct", "LD", "OD", "AD", "gas_glucose", "arabinose", "salicin", "lactose"],
      "decision_tree": [
        "Oxidase + → TCBS colony:",
        "TCBS Yellow (sucrose +): V.cholerae / V.fluvialis / V.furnissii / V.alginolyticus",
        "  0% NaCl growth + → V. cholerae (1%+, 3%+, 6%-, 8%-)",
        "  0% NaCl growth − → AD test:",
        "    AD − → V. alginolyticus (6%+, 8%+)",
        "    AD + → Gas from glucose:",
        "      Gas + → V. furnissii (A/AG TSI)",
        "      Gas − → V. fluvialis (A/A TSI)",
        "TCBS Green (sucrose -): V.parahaemolyticus / V.mimicus / V.vulnificus",
        "  0% NaCl growth + → V. mimicus (1%+, 3%+, 6%-, 8%-)",
        "  0% NaCl growth − → Salicin / Arabinose:",
        "    Salicin −/ Arabinose + → V. parahaemolyticus (1%+, 6%+, 8%±)",
        "    Salicin +/ Arabinose − → V. vulnificus (1%+, 6%±, 8%-)",
        "No TCBS / No hemolysis / small colony BAP → Plesiomonas shigelloides (LD/OD/AD = +/+/+)"
      ],
      "NaCl_profiles": {
        "V_cholerae":        { "0": "+", "1": "+", "3": "+", "6": "±", "8": "-", "TCBS": "Yellow", "TSI": "A/A" },
        "V_fluvialis":       { "0": "-", "1": "+", "3": "+", "6": "+", "8": "+", "TCBS": "Yellow", "TSI": "A/A", "AD": "+" },
        "V_furnissii":       { "0": "-", "1": "+", "3": "+", "6": "+", "8": "+", "TCBS": "Yellow", "TSI": "A/AG", "AD": "+", "gas": "+" },
        "V_alginolyticus":   { "0": "-", "1": "+", "3": "+", "6": "+", "8": "+", "TCBS": "Yellow", "TSI": "A/A", "AD": "-" },
        "V_parahaemolyticus":{ "0": "-", "1": "+", "3": "+", "6": "+", "8": "±", "TCBS": "Green",  "TSI": "K/A", "Arabinose": "+", "Salicin": "-" },
        "V_mimicus":         { "0": "+", "1": "+", "3": "+", "6": "±", "8": "-", "TCBS": "Green",  "TSI": "K/A" },
        "V_vulnificus":      { "0": "-", "1": "+", "3": "+", "6": "±", "8": "-", "TCBS": "Green",  "TSI": "K/A", "Lactose": "+", "Salicin": "+" }
