    "gpb": {
      "id": "gpb",
      "label": "Gram Positive Bacilli",
      "gram": "positive",
      "morphology": "bacilli",
      "key_tests": ["catalase", "spore", "motility", "hemolysis", "H2S_TSI", "CAMP", "esculin", "hippurate"],
      "decision_tree": [
        "Spore former + Large rod → Bacillus spp.",
        "  β-hemolysis + Motile → B. cereus",
        "  γ-hemolysis + Non-motile → B. anthracis",
        "Non-spore former → Catalase test:",
        "  Catalase + →",
        "    Motile + Bile esculin + → Listeria monocytogenes (CAMP+)",
        "    Non-motile → Corynebacterium spp.",
        "      Tinsdale halo (+) → C. diphtheriae (Elek test for toxin)",
        "      Tinsdale (-), no tox gene → C. pseudotuberculosis / C. ulcerans",
        "  Catalase - →",
        "    H2S in TSI + → check colony size:",
        "      Pinpoint + β-hemolysis: Erysipelothrix (vet) or Arcanobacterium",
        "      Non-pinpoint: Gardnerella / Arcanobacterium",
        "    No H2S → CO2 clue cell → Gardnerella vaginalis"
      ],
      "organisms": {
        "L_monocytogenes": {
          "name": "Listeria monocytogenes",
          "colony_bap": "Small grey-white, narrow β-hemolysis, 1-2mm; cold enrichment at 4°C",
          "gram_stain": "Small GP coccobacilli/short rods, may form V or L shape",
          "media": ["Blood agar 37°C", "Oxford agar (selective)", "PALCAM agar"],
          "condition": "Aerobic/Facultative, also grows at 4°C",
          "tests": {
            "catalase": "+",
            "oxidase": "-",
            "motility_25C": "+ (tumbling/umbrella in semisolid agar)",
            "motility_37C": "- or weak",
            "hemolysis": "β (narrow)",
            "camp_test": "+",
            "esculin": "+",
            "hippurate": "+",
            "rhamnose": "+",
            "glucose": "+",
            "mannitol": "-",
            "xylose": "-",
            "H2S_TSI": "-"
          }
        },
