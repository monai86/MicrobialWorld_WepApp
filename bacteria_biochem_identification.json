      "identification_flowchart": {
        "step1_gram_stain_arrangement": [
          { "arrangement": "cluster",  "organism": "Staphylococcus" },
          { "arrangement": "chain",    "organisms": ["Streptococcus", "Enterococcus"] },
          { "arrangement": "tetrad",   "organism": "Micrococcus" }
        ],
        "step2_media": ["Blood agar", "MacConkey agar"],
        "step3_catalase": {
          "positive": ["Staphylococcus", "Micrococcus"],
          "negative": ["Streptococcus", "Enterococcus"]
        },
        "step4_key_tests": {
          "catalase_positive_pathway": {
            "tests_to_do": ["Coagulase", "Glucose O/F", "OD", "Novobiocin"],
            "notes": {
              "Staphylococcus": "white colony",
              "Micrococcus": "colorful colony"
            }
          },
          "catalase_negative_pathway": {
            "tests_to_do": ["Bile esculin", "6.5% NaCl"],
            "if_suspect_Streptococcus": {
              "alpha_hemolysis": ["Optochin (use Candle jar)"],
              "beta_hemolysis": ["PPR", "Bacitracin"]
            },
            "if_suspect_Enterococcus": {
              "tests": ["Motile", "Arabinose", "Raffinose", "Sorbitol", "Mannitol"]
            }
          }
        }
      },

      "overview_table": {
        "columns": ["Organism", "Cell arrangement", "Catalase", "Glucose O/F", "Further tests"],
        "rows": [
          { "organism": "Staphylococcus",             "arrangement": "Cluster, single, pair",          "catalase": "+",  "glucose_of": "+/+",     "further": "Table 1.1" },
          { "organism": "Micrococcus",                "arrangement": "Cluster, tetrad, single, pair",  "catalase": "+",  "glucose_of": "+/-, -/-", "further": "Table 1.1" },
          { "organism": "Streptococcus/Enterococcus", "arrangement": "Long chain, short chain, pair",  "catalase": "-",  "glucose_of": null,       "further": "Table 1.2" }
        ]
      },

      "differentiation_tables": {

